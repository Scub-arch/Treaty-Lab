# Anthropic API key — used by dev tooling (scripts/chat.ts) only.
ANTHROPIC_API_KEY=your_anthropic_key_here

# Database (Prisma). Local dev + CI use SQLite; production uses Postgres.
#   dev:  file:./dev.db
#   prod: postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public
DATABASE_URL="file:./dev.db"

# --- SEC-001 authentication ---------------------------------------------------
# Base URL used to build magic-link sign-in URLs. Optional in dev (falls back to
# the incoming request origin). Set explicitly in production so links point at
# the public hostname even behind a proxy/CDN.
APP_URL=https://your-deployment.example.com

# Magic-link email delivery (SEC-004). In dev the link is printed to the server
# console (and returned in the /api/auth/signin response). For production, set
# BOTH of the following and src/lib/auth/email.ts sends via the Resend HTTP API
# (no SDK dependency). With either unset, the console sender is used (no email is
# sent, no external service contacted — safe for CI and local dev).
# RESEND_API_KEY=re_your_resend_api_key
# EMAIL_FROM="Treaty-Lab <no-reply@your-verified-domain>"

# Admin access (AUDIT-004a). Comma/space-separated allowlist of admin emails
# (case-insensitive) — a signed-in session whose email is listed is treated as an
# admin (e.g. for the read-only /admin/audit surface). Empty/unset ⇒ NO admins.
# ADMIN_EMAILS=you@example.com, ops@example.com

# --- AI-003 Databricks gateway auth -------------------------------------------
# Production uses a service-principal (M2M) OAuth client. When both are set,
# src/lib/llm gets tokens from <DATABRICKS_HOST>/oidc/v1/token (no CLI, no PAT).
# DATABRICKS_CLIENT_ID=your_service_principal_application_id
# DATABRICKS_CLIENT_SECRET=your_service_principal_oauth_secret
#
# Local dev resolves auth via the cached `databricks auth login` token / CLI.
# DATABRICKS_HOST overrides the workspace host; DATABRICKS_TOKEN is a legacy PAT.
# DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# DATABRICKS_TOKEN=dapi...

# --- DPL-002 observability ----------------------------------------------------
# Structured logging (pino → JSON on stdout). Level: trace|debug|info|warn|error.
# LOG_LEVEL=info
# OTEL_SERVICE_NAME labels the logs (and future OTel traces).
# OTEL_SERVICE_NAME=treaty-lab
