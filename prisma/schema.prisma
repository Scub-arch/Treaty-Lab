// Treaty-Lab: international treaty database & explorer
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Treaty {
  id                 String    @id @default(cuid())
  slug               String    @unique
  name               String
  shortName          String?
  openedAt           DateTime
  enteredIntoForceAt DateTime?
  depository         String?
  summary            String?
  fullText           String
  sourceUrl          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  topics     Topic[]     @relation("TreatyTopics")
  signatures Signature[]
  // DATA-002: projects that operate under this treaty (many-to-many).
  relatedProjects ProjectAssessment[] @relation("ProjectTreaties")

  @@index([openedAt])
  @@index([enteredIntoForceAt])
}

model Party {
  id   String @id @default(cuid())
  code String @unique // ISO 3166-1 alpha-2 (e.g. "US", "FR") or org code (e.g. "UN", "EU")
  name String
  type String // "country" | "organization"

  signatures Signature[]

  @@index([type])
}

model Signature {
  id          String    @id @default(cuid())
  treatyId    String
  partyId     String
  signedAt    DateTime?
  ratifiedAt  DateTime?
  reservation String?
  createdAt   DateTime  @default(now())

  treaty Treaty @relation(fields: [treatyId], references: [id], onDelete: Cascade)
  party  Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@unique([treatyId, partyId])
  @@index([treatyId])
  @@index([partyId])
  @@index([signedAt])
}

model Topic {
  id       String  @id @default(cuid())
  slug     String  @unique
  name     String
  parentId String?

  parent   Topic?   @relation("TopicHierarchy", fields: [parentId], references: [id])
  children Topic[]  @relation("TopicHierarchy")
  treaties Treaty[] @relation("TreatyTopics")
}

// ----------------------------------------------------------------------------
// DATA-001: content collections (evidence / indicators / projects / explainers /
// modules) promoted from src/content/*.json to first-class models.
//
// Dual-target notes (SQLite local/CI + Postgres prod):
//   * value arrays are stored as `Json` (SQLite has no Prisma scalar lists)
//   * categorical fields are `String` — the TS string-literal unions in
//     src/lib/content/types.ts stay the source of truth; the seed validates them
//   * cross-collection slug references become FK relations; edges that CITE
//     evidence (or reference another collection) use `onDelete: Restrict`,
//     ownership edges (child of a project/claim/etc.) use `Cascade`
//   * ordered arrays carry an `order Int` so the seed round-trips exactly
//   * audit columns (version / editedBy / deletedAt) are deferred to DATA-003
// ----------------------------------------------------------------------------

model EvidenceItem {
  id           String  @id @default(cuid())
  slug         String  @unique
  title        String
  sourceType   String // SourceType union
  author       String?
  publishedAt  String? // ISO date or YYYY — kept as text to preserve mixed formats
  url          String?
  citation     String?
  reliability  String // EvidenceStrength union
  plainSummary String
  tags         Json // string[]
  supports     Json // string[]
  limitations  Json? // string[] | undefined

  claimSources     ClaimSource[]
  indicatorSources IndicatorSource[]
  projectSources   ProjectSource[]
  financeSources   ProjectFinanceSource[]
  explainerLinks   ExplainerEvidence[]
}

model Indicator {
  id           String  @id @default(cuid())
  slug         String  @unique
  domain       String // Domain union
  name         String
  summary      String
  value        String
  numericValue Float?
  unit         String?
  severity     String // Severity union
  trend        String // Trend union
  note         String?
  updatedAt    String // content's ISO date — NOT a Prisma-managed column

  sources           IndicatorSource[]
  featuredInModules ModuleFeaturedIndicator[]
}

model ProjectAssessment {
  id                            String  @id @default(cuid())
  slug                          String  @unique
  name                          String
  shortName                     String?
  status                        String // ProjectStatus union
  summary                       String
  location                      String
  proponent                     String
  governmentObjective           String
  proponentObjective            String
  evidenceConfidence            String // EvidenceStrength union
  lastReviewed                  String // ISO date
  jurisdictions                 Json // string[]
  domains                       Json // Domain[]
  governanceQuestions           Json // string[]
  recommendedCommunityQuestions Json // string[]

  parties           PartyReference[]
  claims            Claim[]
  finance           ProjectFinance?
  primarySources    ProjectSource[]
  explainerLinks    ExplainerProject[]
  featuredInModules ModuleFeaturedProject[]
  // DATA-002: treaties this project operates under (many-to-many). Empty is
  // meaningful — an unceded-territory project (e.g. Cedar LNG) has no treaty FK.
  relatedTreaties   Treaty[]               @relation("ProjectTreaties")
}

model ProjectFinance {
  id                String  @id @default(cuid())
  projectId         String  @unique
  structure         String
  totalCostEstimate String?
  costOverrunsNoted String?
  loanGuarantor     String?
  riskCarrier       String

  project ProjectAssessment      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sources ProjectFinanceSource[]
}

model PlainLanguageExplainer {
  id          String @id @default(cuid())
  slug        String @unique
  question    String
  shortAnswer String
  body        String

  relatedEvidence ExplainerEvidence[]
  relatedProjects ExplainerProject[]
}

model ModuleConfig {
  id      String @id @default(cuid())
  slug    String @unique // Domain union
  title   String
  tagline String
  lede    String

  featuredIndicators ModuleFeaturedIndicator[]
  featuredProjects   ModuleFeaturedProject[]
}

// --- child rows (owned by a project) ---------------------------------------

model PartyReference {
  id           String  @id @default(cuid())
  projectId    String
  name         String
  role         String
  statementUrl String?
  order        Int

  project ProjectAssessment @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Claim {
  id        String @id @default(cuid())
  projectId String
  group     String // "firstNationImplications" | "treatyAndWaterRisk" | "financeRisk"
  kind      String // Claim.kind union
  text      String
  order     Int

  project ProjectAssessment @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sources ClaimSource[]

  @@index([projectId])
}

// --- evidence-citation joins (SourceReference => FK, onDelete: Restrict) ----

model ClaimSource {
  id         String @id @default(cuid())
  claimId    String
  evidenceId String
  citing     String
  order      Int

  claim    Claim        @relation(fields: [claimId], references: [id], onDelete: Cascade)
  evidence EvidenceItem @relation(fields: [evidenceId], references: [id], onDelete: Restrict)

  @@index([claimId])
  @@index([evidenceId])
}

model IndicatorSource {
  id          String @id @default(cuid())
  indicatorId String
  evidenceId  String
  citing      String
  order       Int

  indicator Indicator    @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  evidence  EvidenceItem @relation(fields: [evidenceId], references: [id], onDelete: Restrict)

  @@index([indicatorId])
  @@index([evidenceId])
}

model ProjectSource {
  id         String @id @default(cuid())
  projectId  String
  evidenceId String
  citing     String
  order      Int

  project  ProjectAssessment @relation(fields: [projectId], references: [id], onDelete: Cascade)
  evidence EvidenceItem      @relation(fields: [evidenceId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([evidenceId])
}

model ProjectFinanceSource {
  id         String @id @default(cuid())
  financeId  String
  evidenceId String
  citing     String
  order      Int

  finance  ProjectFinance @relation(fields: [financeId], references: [id], onDelete: Cascade)
  evidence EvidenceItem   @relation(fields: [evidenceId], references: [id], onDelete: Restrict)

  @@index([financeId])
  @@index([evidenceId])
}

// --- cross-collection slug references => FK joins --------------------------

model ExplainerEvidence {
  id          String @id @default(cuid())
  explainerId String
  evidenceId  String
  order       Int

  explainer PlainLanguageExplainer @relation(fields: [explainerId], references: [id], onDelete: Cascade)
  evidence  EvidenceItem           @relation(fields: [evidenceId], references: [id], onDelete: Restrict)

  @@unique([explainerId, evidenceId])
  @@index([evidenceId])
}

model ExplainerProject {
  id          String @id @default(cuid())
  explainerId String
  projectId   String
  order       Int

  explainer PlainLanguageExplainer @relation(fields: [explainerId], references: [id], onDelete: Cascade)
  project   ProjectAssessment      @relation(fields: [projectId], references: [id], onDelete: Restrict)

  @@unique([explainerId, projectId])
  @@index([projectId])
}

model ModuleFeaturedIndicator {
  id          String @id @default(cuid())
  moduleId    String
  indicatorId String
  order       Int

  module    ModuleConfig @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  indicator Indicator    @relation(fields: [indicatorId], references: [id], onDelete: Restrict)

  @@unique([moduleId, indicatorId])
  @@index([indicatorId])
}

model ModuleFeaturedProject {
  id        String @id @default(cuid())
  moduleId  String
  projectId String
  order     Int

  module  ModuleConfig      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  project ProjectAssessment @relation(fields: [projectId], references: [id], onDelete: Restrict)

  @@unique([moduleId, projectId])
  @@index([projectId])
}

// ----------------------------------------------------------------------------
// SEC-001: authentication (hand-rolled session + magic-link).
//
// See docs/SEC-001-PLAN.md. Dual-target safe (no enums, no scalar lists) so the
// Postgres generator keeps working. Session.sessionToken and
// VerificationToken.token store SHA-256 HASHES, never the raw token — the cookie
// / magic link carries the raw value, validation hashes and looks up by hash.
// ----------------------------------------------------------------------------

model Org {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  sessions Session[]
  quota    Quota?
}

// SEC-002: per-org rate-limit overrides. Absent → the limiter uses defaults
// (10 chat req/min per user, 100/hour per org). Admin-edit UI is deferred.
model Quota {
  id            String   @id @default(cuid())
  orgId         String   @unique
  userPerMinute Int
  orgPerHour    Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  orgId         String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  org          Org           @relation(fields: [orgId], references: [id], onDelete: Restrict)
  accounts     Account[]
  sessions     Session[]
  chatSessions ChatSession[]

  @@index([orgId])
}

// OAuth account-linking table. Unused by email-only sign-in today; present so a
// future OAuth provider does not require a migration.
model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String // "email" | "oauth" | "oidc"
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique // SHA-256 hash of the raw cookie token
  userId       String
  orgId        String
  expires      DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Org  @relation(fields: [orgId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([orgId])
  @@index([expires])
}

model VerificationToken {
  identifier String // email the magic link was issued for
  token      String   @unique // SHA-256 hash of the raw magic-link token
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@index([expires])
}

// ----------------------------------------------------------------------------
// UI-002: persisted /ask conversations. Named ChatSession/ChatTurn to avoid
// colliding with the auth Session model. Scoped to the signed-in user.
// ----------------------------------------------------------------------------

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  turns ChatTurn[]

  @@index([userId])
  @@index([updatedAt])
}

model ChatTurn {
  id            String   @id @default(cuid())
  chatSessionId String
  question      String
  answer        String
  reasoning     String?
  model         String?
  projectSlug   String?
  domainSlug    String?
  createdAt     DateTime @default(now())

  session ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId])
}
